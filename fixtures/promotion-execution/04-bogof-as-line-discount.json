            "totalDiscountAmount": 9,
            "totalCartLevelDiscountAmount": 0,
            "totalLineLevelDiscountAmount": 9,
            "appliedCartPromotionDetails": [],
            "cartLineDetails": [
              {
                "cartLineItemId": "line-pizza",
                "cartLineProduct": "Pizza",
                "cartLineItemQuantity": 1,
                "cartLineItemAmountBeforeDiscount": 100,
                "cartLineItemAmountAfterDiscount": 100,
                "totalCartLineItemDiscountAmount": 0,
                "totalCartLinePromotionsDiscountAmount": 0,
                "totalCartPromotionsDistributedDiscountAmount": 0,
                "appliedCartLinePromotionDetails": []
              },
              {
                "cartLineItemId": "line-burger",
                "cartLineProduct": "Burger",
                "cartLineItemQuantity": 1,
                "cartLineItemAmountBeforeDiscount": 9,
                "cartLineItemAmountAfterDiscount": 0,
                "totalCartLineItemDiscountAmount": 9,
                "totalCartLinePromotionsDiscountAmount": 9,
                "totalCartPromotionsDistributedDiscountAmount": 0,
                "appliedCartLinePromotionDetails": [
                  {
                    "promotionId": "0c8xx00000006TdAAI",
                    "displayName": "Buy 1 Pizza, Get 1 Burger Free",
                    "cartLineItemAmountBeforeDiscount": 9,
                    "cartLineItemAmountAfterDiscount": 0,
                    "cartLineItemDiscountAmount": 9,
